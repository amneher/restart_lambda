modules = ["python-3.12"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Test Lambda"

[[workflows.workflow]]
name = "Test Lambda"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python test_lambda.py"

[workflows.workflow.metadata]
outputType = "console"

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]
